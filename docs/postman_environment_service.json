{
  "info": {
    "name": "Smart City — Role 4: Environment Service",
    "_postman_id": "role4-env-collection-v1",
    "description": "Koleksi API Environment Service (port 8002) — Smart City Platform\nRole 4: Environment & IoT Workflow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:3000",  "type": "string", "description": "URL API Gateway (port 3000)" },
    { "key": "directUrl","value": "http://localhost:8002",  "type": "string", "description": "Akses langsung env-service" },
    { "key": "token",    "value": "",                        "type": "string", "description": "JWT Bearer token dari OAuth" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{directUrl}}/health", "host": ["{{directUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Sensor Data",
      "item": [
        {
          "name": "POST /api/environment/sensor — Normal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sensor_id\": \"ESP32-A-01\",\n  \"zone\": \"A\",\n  \"aqi\": 85.5,\n  \"temperature\": 31.2,\n  \"humidity\": 72.1,\n  \"flood_level\": 5.0,\n  \"pm25\": 35.2,\n  \"pm10\": 48.1,\n  \"no2\": 42.3,\n  \"co\": 1.2,\n  \"o3\": 55.0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/environment/sensor",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","sensor"]
            }
          }
        },
        {
          "name": "POST /api/environment/sensor — AQI HIGH (trigger alert)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sensor_id\": \"ESP32-B-01\",\n  \"zone\": \"B\",\n  \"aqi\": 145.7,\n  \"temperature\": 34.0,\n  \"humidity\": 80.0,\n  \"flood_level\": 12.0,\n  \"pm25\": 68.0,\n  \"pm10\": 90.0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/environment/sensor",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","sensor"]
            }
          }
        },
        {
          "name": "POST /api/environment/sensor — FLOOD CRITICAL (trigger alert)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sensor_id\": \"ESP32-C-01\",\n  \"zone\": \"C\",\n  \"aqi\": 90.0,\n  \"temperature\": 29.5,\n  \"humidity\": 95.0,\n  \"flood_level\": 67.5,\n  \"pm25\": 38.0,\n  \"pm10\": 52.0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/environment/sensor",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","sensor"]
            }
          }
        },
        {
          "name": "POST /api/environment/sensor — Validation Error (missing fields)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zone\": \"X\",\n  \"aqi\": -5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/environment/sensor",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","sensor"]
            }
          }
        }
      ]
    },
    {
      "name": "Current Conditions",
      "item": [
        {
          "name": "GET /api/environment/current — Semua zona",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/current",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","current"]
            }
          }
        },
        {
          "name": "GET /api/environment/current?zone=A",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/current?zone=A",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","current"],
              "query": [{ "key": "zone", "value": "A" }]
            }
          }
        }
      ]
    },
    {
      "name": "History",
      "item": [
        {
          "name": "GET /api/environment/zones/A — Riwayat Zona A",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/zones/A?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","zones","A"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "GET /api/environment/zones/B — Filter tanggal",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/zones/B?from=2026-06-01&to=2026-06-09&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","zones","B"],
              "query": [
                { "key": "from",  "value": "2026-06-01" },
                { "key": "to",    "value": "2026-06-09" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "GET /api/environment/alerts — Alert aktif semua zona",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","alerts"]
            }
          }
        },
        {
          "name": "GET /api/environment/alerts?zone=B",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/alerts?zone=B",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","alerts"],
              "query": [{ "key": "zone", "value": "B" }]
            }
          }
        },
        {
          "name": "GET /api/environment/alerts?status=all",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/alerts?status=all",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","alerts"],
              "query": [{ "key": "status", "value": "all" }]
            }
          }
        },
        {
          "name": "PUT /api/environment/alerts/1/resolve — Operator resolve",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/alerts/1/resolve",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","alerts","1","resolve"]
            }
          }
        },
        {
          "name": "GET /api/environment/alerts/1 — Detail alert",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/alerts/1",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","alerts","1"]
            }
          }
        }
      ]
    },
    {
      "name": "Zones",
      "item": [
        {
          "name": "GET /api/environment/zones — Daftar zona",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/environment/zones",
              "host": ["{{baseUrl}}"],
              "path": ["api","environment","zones"]
            }
          }
        }
      ]
    }
  ]
}
