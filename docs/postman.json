{
  "info": {
    "name": "Smart City Platform - Complete Collection",
    "_postman_id": "smart-city-platform-v1",
    "description": "Koleksi lengkap API Smart City Platform\n\nService yang tersedia:\n- Auth Service (Port 3001)\n- API Gateway (Port 3000)\n- Environment Service (Port 8002)\n- Traffic Service (Port 8001)\n- Citizen Service (Port 8080)\n- ML Service (Port 5001)\n\nCara penggunaan:\n1. Register user terlebih dahulu\n2. Login untuk mendapatkan token\n3. Set token ke variable environment 'token'\n4. Testing endpoints dengan Bearer token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "URL API Gateway (port 3000)"
    },
    {
      "key": "authUrl",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "URL Auth Service (port 3001)"
    },
    {
      "key": "envUrl",
      "value": "http://localhost:8002",
      "type": "string",
      "description": "URL Environment Service (port 8002)"
    },
    {
      "key": "trafficUrl",
      "value": "http://localhost:8001",
      "type": "string",
      "description": "URL Traffic Service (port 8001)"
    },
    {
      "key": "citizenUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "URL Citizen Service (port 8080)"
    },
    {
      "key": "mlUrl",
      "value": "http://localhost:5001",
      "type": "string",
      "description": "URL ML Service (port 5001)"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT Bearer token dari OAuth"
    },
    {
      "key": "operatorToken",
      "value": "",
      "type": "string",
      "description": "JWT Bearer token untuk operator"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "description": "Endpoint untuk registrasi dan login user",
      "item": [
        {
          "name": "1.1 Register - Citizen",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"citizen\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "1.2 Register - Operator",
          "request": {
            "method": "POST",
            "header": [
