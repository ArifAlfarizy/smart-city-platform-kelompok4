    {
      "key": "baseUrl",
      "value": "http://103.147.92.135:3040",
      "type": "string",
      "description": "URL API Gateway (port 3040) - Kelompok 4"
    },
    {
      "key": "authUrl",
      "value": "http://103.147.92.135:3042",
