{
    "name": "smartcity/php-environment",
    "description": "Smart City - Environment Service (PHP 8.2 + Slim 4)",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-amqplib/php-amqplib": "^3.6",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
